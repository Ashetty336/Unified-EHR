NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# AES-256-GCM key for at-rest encryption of uploaded medical files.
# 32-byte key, base64 or hex. Server-only secret — rotating it makes existing
# encrypted files unreadable. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MEDICAL_FILES_ENCRYPTION_KEY=
# HAPI FHIR server (never exposed to client)
HAPI_FHIR_URL=
# Microsoft FHIR Converter container (CCDA/HL7v2/JSON/STU3 → FHIR R4)
# docker run -d -p 5000:8080 --name fhir-converter mcr.microsoft.com/healthcareapis/fhir-converter:1.0.430-preview
FHIR_CONVERTER_URL=http://localhost:5000
# Optional template collection refs (ACR/OCI ref). Local mount paths are NOT
# supported by the preview container. To customize templates push them to a
# local OCI registry (oras push) and reference them here.
# FHIR_CONVERTER_TEMPLATE_CCDA=microsofthealth/ccdatemplates:default

# Groq API — multilingual prescription OCR + translation + medication extraction.
# Server-only secret. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional override for the Groq vision-capable model id.
# Default: meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_MODEL=